# Скопируй в .env и подставь значения. Префиксы соответствуют root.shared.config.

# --- DB_ PostgreSQL ---
# DB_USER - пользователь БД
# DB_PASSWORD - пароль
# DB_HOST - хост (в Docker обычно postgres)
# DB_PORT - порт
# DB_NAME - имя базы
# DB_POOL_SIZE - размер пула соединений SQLAlchemy
# DB_MAX_OVERFLOW - дополнительные соединения сверх pool_size
# DB_POOL_PRE_PING - проверять соединение перед использованием
# DB_POOL_RECYCLE - секунды до пересоздания соединения в пуле

# --- RABBITMQ_ ---
# RABBITMQ_USER - пользователь RabbitMQ
# RABBITMQ_PASS - пароль
# RABBITMQ_HOST - хост брокера
# RABBITMQ_PORT - порт AMQP

# --- REDIS_ ---
# REDIS_CONNECTION_URL - полный URL если задан, иначе собирается из HOST/PORT/USER/PASSWORD
# REDIS_USERNAME - пользователь ACL Redis если есть
# REDIS_PASSWORD - пароль
# REDIS_HOST - хост
# REDIS_PORT - порт

# --- DOWNLOADER_ воркер загрузки HTML и http_policy ---
# DOWNLOADER_MAX_RETRIES - попытки при ошибках сети и 5xx
# DOWNLOADER_BASE_DELAY_SECONDS - база задержки между ретраями в downloader
# DOWNLOADER_HTML_EXPIRE_SECONDS - TTL HTML в Redis
# DOWNLOADER_HTTP_IMPERSONATE - дефолтный impersonate curl_cffi без профиля по хосту
# DOWNLOADER_HTTP_TIMEOUT_SECONDS - таймаут ответа HTTP на сессии curl
# DOWNLOADER_HTTP_JITTER_TIMEOUT_MIN_SECONDS - мин секунд случайной паузы перед GET антифрод
# DOWNLOADER_HTTP_JITTER_TIMEOUT_MAX_SECONDS - макс секунд той же паузы
# DOWNLOADER_HTTP_MAX_CLIENTS - параллельные easy handles в пуле curl

# --- SCHEDULER_ ---
# SCHEDULER_ENABLED - включить планировщик
# SCHEDULER_INTERVAL_SECONDS - период тика
# SCHEDULER_STALE_AFTER_SECONDS - считать URL устаревшим для повторной отправки
# SCHEDULER_MAX_URLS_PER_TICK - лимит URL за тик
# SCHEDULER_PUBLISH_GAP_SECONDS - пауза между publish в Rabbit
# SCHEDULER_FORCE_REFRESH - передавать force_refresh в сообщениях

# --- PLAYWRIGHT_ ---
# PLAYWRIGHT_HEADLESS - запускать браузер без UI
# PLAYWRIGHT_NAVIGATION_TIMEOUT_MS - таймаут навигации
# PLAYWRIGHT_VIEWPORT_WIDTH - ширина окна
# PLAYWRIGHT_VIEWPORT_HEIGHT - высота окна

# --- EMBEDDING_ ---
# EMBEDDING_ENABLED - включить векторизацию после normalize
# EMBEDDING_MODEL_NAME - модель sentence-transformers

# --- QDRANT_ ---
# QDRANT_ENABLED - включить векторный контур и hybrid search с векторной частью
# QDRANT_URL - URL Qdrant
# QDRANT_API_KEY - ключ если нужен
# QDRANT_COLLECTION_NAME - имя коллекции
# QDRANT_VECTOR_SIZE - размер вектора
